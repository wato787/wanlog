# ローカル開発用。コピーして .dev.vars を作成し値を設定すること。
# .dev.vars は git に含めない。
# 本番では wrangler secret put R2_ACCESS_KEY_ID 等で設定。

LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
JWT_SECRET=
API_ORIGIN=http://localhost:8787
FRONTEND_ORIGIN=http://localhost:5173

# R2 presigned URL 用（Dashboard → R2 → Manage R2 API Tokens で発行）
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
# 省略時は wanlog-media
# R2_BUCKET_NAME=wanlog-media
# CORS: ブラウザ直アップロード用に R2 バケットに CORS を設定すること（cors-policy.example.json を参照、aws s3api put-bucket-cors）
